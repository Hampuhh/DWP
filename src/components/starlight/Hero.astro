---
import type { Props } from '@astrojs/starlight/props';
import Landing from '../landing/Landing.astro';

const { entry } = Astro.props;
const isHome = entry?.slug === '' || entry?.slug === 'index' || entry?.id === 'index.md';
---

{
  /* Home: render full editorial Landing.
     Otras splash pages (Mi closet, Generador, etc.): no rendereamos hero — el
     componente de la página provee su propia cabecera editorial. */
}
{isHome && <Landing />}
