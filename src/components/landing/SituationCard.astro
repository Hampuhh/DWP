---
import {
  Coffee, Sun, Heart, Cake, Flower2, Plane, Film, UtensilsCrossed,
} from '@lucide/svelte';

interface Props {
  slug: string;
  titulo: string;
  descripcion: string;
  icon: string;
  cat?: string;
  numero?: string;
  dark?: boolean;
  mood?: string;     // hex de fondo del visual
  moodInk?: string;  // hex del icono sobre el visual (default = mismo color del texto)
}

const {
  slug, titulo, descripcion, icon, cat, numero, dark = false,
  mood, moodInk,
} = Astro.props;

const iconMap: Record<string, any> = {
  coffee: Coffee,
  sun: Sun,
  heart: Heart,
  cake: Cake,
  flower: Flower2,
  plane: Plane,
  film: Film,
  utensils: UtensilsCrossed,
};

const Icon = iconMap[icon] ?? Sun;

// Estilos inline para que cada situación tenga su propio "mood"
const visualStyle = mood
  ? `background:${mood};${moodInk ? `color:${moodInk};` : ''}`
  : '';
---

<a class={`ed-tile ${dark ? 'ed-tile--dark' : ''}`} href={`./outfits/${slug}`}>
  <div class="ed-tile__visual" style={visualStyle}>
    <Icon size={120} strokeWidth={0.8} class="ed-tile__visual-icon" />
    <div class="ed-tile__noise"></div>
  </div>

  <div class="ed-tile__overlay">
    {numero && <span class="ed-tile__num">{numero}</span>}
    <div class="ed-tile__body">
      <h3 class="ed-tile__title">{titulo}</h3>
      <p class="ed-tile__desc">{descripcion}</p>
    </div>
    <div class="ed-tile__foot">
      {cat && <span class="ed-tile__cat">{cat}</span>}
      <Icon size={20} strokeWidth={1.2} />
    </div>
  </div>
</a>

<style>
  .ed-tile {
    position: relative;
    display: grid;
    grid-template-rows: 55% 1fr;
    background: var(--color-marfil);
    color: var(--color-negro);
    text-decoration: none;
    border: none;
    min-height: 360px;
    overflow: hidden;
    transition: background var(--motion-base);
  }
  .ed-tile:hover { background: var(--color-crema); }

  /* ── Visual block (mood color + icon gigante de fondo) ───── */
  .ed-tile__visual {
    position: relative;
    overflow: hidden;
    display: grid;
    place-items: center;
    color: rgba(42, 40, 37, 0.22);  /* icon faded */
    border-bottom: 1px solid currentColor;
    border-bottom-color: var(--color-linea);
  }
  .ed-tile__visual :global(.ed-tile__visual-icon),
  .ed-tile__visual > :global(svg) {
    transition: transform var(--motion-slow);
  }
  .ed-tile:hover .ed-tile__visual > :global(svg) {
    transform: scale(1.05);
  }
  /* Textura de noise editorial sutil */
  .ed-tile__noise {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(135deg,
        rgba(42, 40, 37, 0.03) 0 1px,
        transparent 1px 8px);
    pointer-events: none;
  }

  /* ── Overlay con metadata ───────────────────────────────── */
  .ed-tile__overlay {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6) var(--space-6);
  }
  .ed-tile__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    color: var(--color-terracota);
    line-height: 1;
  }
  .ed-tile__title {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.05;
    font-weight: var(--weight-medium);
    letter-spacing: -0.005em;
    margin: 0 0 var(--space-2);
    color: var(--color-negro);
  }
  .ed-tile__title em { font-style: italic; color: var(--color-terracota); }
  .ed-tile__desc {
    font-family: var(--font-sans);
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--color-negro-60);
    margin: 0;
    max-width: 28ch;
  }
  .ed-tile__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-3);
    color: var(--color-negro);
    opacity: 0.85;
  }
  .ed-tile__cat {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-negro-45);
  }
  .ed-tile:hover .ed-tile__title { color: var(--color-terracota); }

  /* ── Variante tile dark (negro inverso) ─────────────────── */
  .ed-tile--dark { background: var(--color-tinta); color: var(--color-marfil); }
  .ed-tile--dark .ed-tile__visual { color: rgba(245, 241, 234, 0.22); }
  .ed-tile--dark .ed-tile__title,
  .ed-tile--dark .ed-tile__title em,
  .ed-tile--dark:hover .ed-tile__title { color: var(--color-marfil); }
  .ed-tile--dark .ed-tile__desc { color: rgba(245, 241, 234, 0.7); }
  .ed-tile--dark .ed-tile__cat { color: var(--color-terracota-soft); }
  .ed-tile--dark .ed-tile__num { color: var(--color-terracota-soft); }
  .ed-tile--dark .ed-tile__visual { border-bottom-color: rgba(245, 241, 234, 0.12); }
  .ed-tile--dark:hover { background: #000; }

  @media (max-width: 540px) {
    .ed-tile { min-height: 280px; }
    .ed-tile__overlay { padding: var(--space-4) var(--space-5) var(--space-5); }
  }
</style>
